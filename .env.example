# Required environment for alpha-server.
#
# Copy to .env at the repo root and edit if needed. Settings uses
# extra="forbid" — every variable here is required; nothing extra is allowed.
#
# Defaults below assume **local Ollama**, no API keys, no cloud. Claude Code
# itself (the harness Alpha runs in) authenticates via your Pro Max OAuth
# separately — none of that touches this file.
#
# To pull the models for the defaults:
#     ollama pull dengcao/Qwen3-Embedding-4B:F16        # ~8 GB; required
#     ollama pull qwen2.5:7b                            # ~4.7 GB; or pick another
#
# Ollama ignores api_key entirely — any non-empty string works.

# === Chat client (used by /hooks/memories to extract search queries) ===
# Any OpenAI-protocol endpoint. The model needs to honor strict JSON-array
# response_format. Qwen 2.5 7B is the smallest model that's been verified.
chat_api_key=ollama
chat_base_url=http://localhost:11434/v1
chat_model=qwen2.5:7b

# === Embedding client (used by store_memory and search_memories) ===
# WARNING: the code is hard-coded for Qwen 3 Embedding 4B in two places:
#   1. cortex.memories.embedding_qwen is vector(2560) — Qwen 3 Embedding 4B's
#      dimension. Swap models and you must DROP and recreate the column at
#      the new dim. See schema/cortex-bootstrap.sql.
#   2. llm.format_query_for_embedding prepends "Instruct: ...\nQuery: ..." —
#      Qwen 3 Embedding 4B's required input format. Other models perform
#      worse with that prefix.
embedding_api_key=ollama
embedding_base_url=http://localhost:11434/v1
embedding_model=dengcao/Qwen3-Embedding-4B:F16

# === Datastores (point at the compose-dev.yml dev stack by default) ===
# Port 5433 avoids conflicts with any local Postgres running on the default 5432.
database_url=postgresql://postgres:postgres@127.0.0.1:5433/postgres
redis_url=redis://127.0.0.1:6379/0

# === Observability ===
# Logfire is optional in practice. An empty token disables backend send;
# spans still get created and dropped locally. You only need a real token
# if you want to view traces in the Logfire UI.
logfire_token=
otel_service_name=alpha-server

# === Local clock — the "household register" ===
timezone=America/New_York

# ===========================================================================
# Alternative: cloud-LLM mode (commented out)
# ===========================================================================
# If you'd rather hit OpenAI / OpenRouter / a hosted LLM gateway, replace
# the chat_* and embedding_* lines above with something like:
#
#     chat_api_key=sk-...
#     chat_base_url=https://api.openai.com/v1
#     chat_model=gpt-4o-mini
#
#     embedding_api_key=sk-...
#     embedding_base_url=https://api.openai.com/v1
#     embedding_model=text-embedding-3-large
#
# OpenAI text-embedding-3-large is 3072-dim; -3-small is 1536; ada-002 is
# 1536. Each requires a schema change to match — see schema/cortex-bootstrap.sql.
